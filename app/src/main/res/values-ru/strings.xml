    <!-- About (v1.1.0) -->
    <string name="about">О приложении</string>
    <string name="about_version">Версия %1$s</string>
    <string name="about_description">ApexMark — лёгкий полностью локальный конвертер буфера обмена: одно касание в пузыре или уведомлении переключает Markdown, rich-clip в стиле WPS и HTML, чтобы вставлять таблицы и стили в WeChat, WPS, Feishu и др. Без фонового чтения буфера, без сети. Версия 1.1.0 упрощает уведомление и оставляет таблицы по умолчанию нейтральными.</string>
