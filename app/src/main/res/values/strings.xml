    <string name="about">About</string>
    <string name="about_version">Version %1$s</string>
    <string name="about_description">ApexMark is a featherweight, system-level Markdown ↔ Rich Text converter built for mobile productivity. Copy Markdown anywhere, tap once, paste fully-formatted rich text into WeChat, WPS, Feishu, DingTalk, email, or any editor — and long-press to convert in the opposite direction. Small footprint, zero background polling, zero network. All conversion happens locally on your device.</string>
